<DefaultWindow xmlns="https://spacestation14.io"
            Title="{Loc 'crayon-window-title'}"
            MinSize="450 500"
            SetSize="450 500">
    <BoxContainer Orientation="Vertical">
        <ColorSelectorSliders Name="ColorSelector" Visible="False" />
        <LineEdit Name="Search" Margin="0 0 0 8" PlaceHolder="{Loc 'crayon-window-placeholder'}" />
        <ScrollContainer VerticalExpand="True">
            <BoxContainer Name="Grids" Orientation="Vertical">
            </BoxContainer>
        </ScrollContainer>
        <!-- DS-14 Start -->
        <BoxContainer Orientation="Horizontal" Margin="0 0 0 8">
            <Label Text="Поворот:" Margin="0 0 8 0" VerticalAlignment="Center"/>
            <SpinBox Name="RotationInput" Value="0" HorizontalExpand="True"/>
        </BoxContainer>
        <!-- DS-14 End-->
    </BoxContainer>
</DefaultWindow>
