<DefaultWindow xmlns="https://spacestation14.io"
               Title="{Loc game-preset-create-window-title-democracy}"
               MinSize="400 300"
               SetSize="500 400">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">
        <LineEdit Name="PresetNameEdit" PlaceHolder="{Loc game-preset-name-placeholder}" />
        <ScrollContainer VerticalExpand="True">
            <GridContainer Name="PresetsGrid" Columns="2" />
        </ScrollContainer>
        <Button Name="SaveButton" Text="{Loc game-preset-save-button}" />
    </BoxContainer>
</DefaultWindow>