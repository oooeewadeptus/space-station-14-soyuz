<cartridges:WantedListUiFragment xmlns:cartridges="clr-namespace:Content.Client.CartridgeLoader.Cartridges"
        xmlns="https://spacestation14.io"
        xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
        Orientation="Vertical"
        VerticalExpand="True"
        HorizontalExpand="True">

    <PanelContainer StyleClasses="DS14MenuPanelDark"></PanelContainer>
    <LineEdit Name="SearchBar"
              PlaceHolder="{Loc 'wanted-list-search-placeholder'}"
              HorizontalExpand="True"
              SetHeight="32"
              Margin="4 4 4 2"
              StyleClasses="DS14MenuInput"/>

    <BoxContainer Name="MainContainer"
                  Orientation="Horizontal"
                  HorizontalExpand="True"
                  VerticalExpand="True"
                  Margin="4"
                  SeparationOverride="6">
        <PanelContainer StyleClasses="DS14MenuInset"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        SizeFlagsStretchRatio="1">
            <BoxContainer Orientation="Vertical"
                          HorizontalExpand="True"
                          VerticalExpand="True">
                <Label Text="{Loc 'wanted-list-records-title'}"
                       StyleClasses="DS14MenuListHeader"
                       Margin="2 0 2 4"/>
                <Label Name="NoRecords"
                       Text="{Loc 'wanted-list-label-no-records'}"
                       Align="Center"
                       VAlign="Center"
                       HorizontalExpand="True"
                       VerticalExpand="True"
                       FontColorOverride="DarkGray"/>

                <controls:ListContainer
                    Name="RecordsList"
                    HorizontalExpand="True"
                    VerticalExpand="True"
                    Visible="False"
                    Toggle="True"
                    Group="True" />
            </BoxContainer>
        </PanelContainer>

        <PanelContainer StyleClasses="DS14MenuPanel"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        SizeFlagsStretchRatio="2">
            <BoxContainer Orientation="Vertical"
                          HorizontalExpand="True"
                          VerticalExpand="True">
                <Label Name="RecordUnselected"
                       Text="{Loc 'criminal-records-console-select-record-info'}"
                       Align="Center"
                       VAlign="Center"
                       FontColorOverride="DarkGray"
                       Visible="False"
                       HorizontalExpand="True"
                       VerticalExpand="True" />
                <BoxContainer Name="PersonContainer"
                              Orientation="Vertical"
                              HorizontalExpand="True"
                              VerticalExpand="True"
                              Visible="False">
                    <BoxContainer Orientation="Horizontal" HorizontalExpand="True">
                        <Label Name="PersonName" StyleClasses="DS14MenuTitle" HorizontalExpand="True" ClipText="True"/>
                        <RichTextLabel Name="PersonState" HorizontalAlignment="Right" />
                    </BoxContainer>
                    <PanelContainer StyleClasses="DS14MenuAccentDim" SetHeight="1" Margin="0 5 0 5"/>
                    <ScrollContainer VerticalExpand="True" HScrollEnabled="False">
                        <BoxContainer Name="DataContainer" Orientation="Vertical" SeparationOverride="4">
                            <RichTextLabel Name="TargetAge" />
                            <RichTextLabel Name="TargetJob" />
                            <RichTextLabel Name="TargetSpecies" />
                            <RichTextLabel Name="TargetGender" />
                            <PanelContainer StyleClasses="DS14MenuAccentDim" SetHeight="1" Margin="0 5 0 5"/>
                            <RichTextLabel Name="InitiatorName" VerticalAlignment="Stretch"/>
                            <RichTextLabel Name="WantedReason" VerticalAlignment="Stretch"/>
                            <PanelContainer StyleClasses="DS14MenuAccentDim" SetHeight="1" Margin="0 5 0 5" />
                            <PanelContainer Name="HistoryPanel" StyleClasses="DS14MenuInset">
                                <controls:TableContainer Name="HistoryTable" Columns="3" Visible="False" HorizontalAlignment="Stretch" />
                            </PanelContainer>
                        </BoxContainer>
                    </ScrollContainer>
                </BoxContainer>
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</cartridges:WantedListUiFragment>
