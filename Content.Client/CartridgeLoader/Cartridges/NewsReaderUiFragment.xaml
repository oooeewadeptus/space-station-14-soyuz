<cartridges:NewsReaderUiFragment xmlns:cartridges="clr-namespace:Content.Client.CartridgeLoader.Cartridges"
                               xmlns:gfx="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                               xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                               xmlns:customControls="clr-namespace:Content.Client.Administration.UI.CustomControls"
                               xmlns="https://spacestation14.io"
                               Margin="1 0 2 0"
                               Orientation="Vertical"
                               HorizontalExpand="True"
                               VerticalExpand="True">
    <PanelContainer StyleClasses="DS14MenuPanelDark"></PanelContainer>
    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="5,4,5,2">
        <Button
            Name="Prev"
            MinWidth="64"
            SetHeight="28"
            Disabled="True"
            HorizontalAlignment="Left"
            Text="{Loc 'news-read-ui-prev-text'}"
            ToolTip="{Loc 'news-read-ui-prev-tooltip'}"
            Access="Public"
            HorizontalExpand="True"
            StyleClasses="DS14MenuProfileControl"/>
        <Button
            Name="Next"
            MinWidth="64"
            SetHeight="28"
            Disabled="True"
            HorizontalAlignment="Right"
            Text="{Loc 'news-read-ui-next-text'}"
            ToolTip="{Loc 'news-read-ui-next-tooltip'}"
            StyleClasses="DS14MenuProfileControl"/>
    </BoxContainer>
    <controls:StripeBack Name="ArticleNameContainer">
        <PanelContainer StyleClasses="DS14MenuHeader">
            <Label Name="PageNum" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="4,0,0,0" StyleClasses="DS14MenuSubtitle"/>
            <Label Name="PageName" Align="Center" StyleClasses="DS14MenuTitle"/>
        </PanelContainer>
    </controls:StripeBack>
    <PanelContainer VerticalExpand="True" SizeFlagsStretchRatio="5" StyleClasses="DS14MenuInset">
        <ScrollContainer
                Name="PageTextScroll"
                HScrollEnabled="False"
                HorizontalExpand="True"
                MinSize="0 0"
                SizeFlagsStretchRatio="2"
                VerticalExpand="True">
            <BoxContainer
                Name="PageTextContainer"
                MinSize="0 0"
                Orientation="Vertical"
                SizeFlagsStretchRatio="2"
                VerticalExpand="True">
                <RichTextLabel Margin="8,8,8,8" Name="PageText" VerticalAlignment="Top"/>
            </BoxContainer>
        </ScrollContainer>
    </PanelContainer>

    <BoxContainer Name="InteractionPanel" Orientation="Vertical" HorizontalExpand="True" VerticalExpand="False">
        <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="5,2,5,2">
            <Button
                Name="LikeButton"
                MinWidth="60"
                HorizontalAlignment="Left"
                ToolTip="{Loc 'news-read-ui-like-tooltip'}"
                StyleClasses="DS14MenuProfileControl">
                <BoxContainer Orientation="Horizontal">
                    <Label Text="+" VerticalAlignment="Center"/>
                    <Label Name="LikeCount" Text="0" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </BoxContainer>
            </Button>
            <Button
                Name="DislikeButton"
                MinWidth="60"
                Margin="4,0,0,0"
                HorizontalAlignment="Left"
                ToolTip="{Loc 'news-read-ui-dislike-tooltip'}"
                StyleClasses="DS14MenuProfileControl">
                <BoxContainer Orientation="Horizontal">
                    <Label Text="-" VerticalAlignment="Center"/>
                    <Label Name="DislikeCount" Text="0" Margin="6,0,0,0" VerticalAlignment="Center"/>
                </BoxContainer>
            </Button>
        </BoxContainer>

        <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="False" Margin="5,2,5,3">

            <BoxContainer Orientation="Horizontal" HorizontalExpand="True" SetHeight="88">

                <PanelContainer StyleClasses="DS14MenuInset" HorizontalExpand="True" SizeFlagsStretchRatio="1" Margin="0,2,2,2">
                    <BoxContainer Orientation="Vertical" Margin="4">
                        <LineEdit
                            Name="CommentInput"
                            PlaceHolder="{Loc 'news-read-ui-comment-placeholder'}"
                            HorizontalExpand="True"
                            StyleClasses="DS14MenuInput"/>
                        <Button
                            Name="SendCommentButton"
                            MinWidth="60"
                            Margin="0,4,0,0"
                            HorizontalAlignment="Center"
                            Text="{Loc 'news-read-ui-comment-send'}"
                            ToolTip="{Loc 'news-read-ui-comment-send-tooltip'}"
                            StyleClasses="DS14MenuProfileControl"/>
                    </BoxContainer>
                </PanelContainer>

                <PanelContainer StyleClasses="DS14MenuInset" HorizontalExpand="True" SizeFlagsStretchRatio="1" Margin="2,2,0,2">
                    <ScrollContainer
                        Name="CommentsScroll"
                        HScrollEnabled="False"
                        HorizontalExpand="True"
                        VerticalExpand="True">
                        <BoxContainer
                            Name="CommentsContainer"
                            Orientation="Vertical"
                            HorizontalExpand="True"
                            VerticalExpand="False"/>
                    </ScrollContainer>
                </PanelContainer>

            </BoxContainer>
        </BoxContainer>
    </BoxContainer>

    <BoxContainer Orientation="Horizontal" HorizontalExpand="True" Margin="5,3,5,4">
        <Button
            Name="NotificationSwitch"
            ToolTip="{Loc news-reader-ui-mute-tooltip}"
            MinWidth="20"
            StyleClasses="DS14MenuProfileControl"/>
        <RichTextLabel Margin="5,2,2,2" Name="ShareTime" VerticalAlignment="Top"/>
        <customControls:VSeparator Margin="2 0"/>
        <RichTextLabel Margin="5,2,2,2" Name="Author" VerticalAlignment="Top" HorizontalAlignment="Right"/>
    </BoxContainer>
</cartridges:NewsReaderUiFragment>
